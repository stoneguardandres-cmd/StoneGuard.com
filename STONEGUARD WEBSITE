:root {
  --font-sans: 'Inter', sans-serif;
  --font-serif: 'Playfair Display', serif;

  /* Colors */
  --color-black: #1a1a1a;
  --color-dark-gray: #2d2d2d;
  --color-gray: #4a4a4a;
  --color-light-gray: #ebebeb;
  --color-white: #ffffff;
  --color-accent: #c41e3a;
  --color-accent-light: #e63946;
  --color-accent-dark: #a01830;

  /* Spacing */
  --spacing-xs: 0.5rem;
  --spacing-sm: 1rem;
  --spacing-md: 1.5rem;
  --spacing-lg: 2rem;
  --spacing-xl: 3rem;
  --spacing-2xl: 4rem;
