          <div className="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16">
            {/* Contact Info */}
            {[
              {
                title: 'Teléfono',
                value: '+1 (555) 123-4567',
                href: 'tel:+15551234567',
                icon: '📞',
              },
              {
                title: 'Email',
                value: 'info@stoneguard.com',
                href: 'mailto:info@stoneguard.com',
                icon: '✉️',
